# RadarAgro — Variables de entorno
# Copiar a .env.local para desarrollo local
# En Vercel: Settings → Environment Variables

# APIs externas (frontend — VITE_ prefix requerido para exponer al browser)
VITE_DOLAR_API=https://dolarapi.com/v1
VITE_ARGENTINA_DATOS=https://api.argentinadatos.com/v1

# APIs externas (backend/proxies — sin VITE_ prefix, solo disponibles en serverless)
INDEC_API=https://apis.datos.gob.ar
BCRA_API=https://api.bcra.gob.ar/estadisticas/v4.0/Monetarias
YAHOO_FINANCE=https://query1.finance.yahoo.com/v8/finance/chart